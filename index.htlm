<!DOCTYPE html>  <html lang="en">  
<head>  
  <meta charset="UTF-8" />  
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />  
  <title>DIAZ — AI Chatbot</title>  
  <meta name="description" content="DIAZ is a premium Apple-inspired AI chatbot built with HTML, CSS, and JavaScript." />  
  <link rel="stylesheet" href="style.css" />  
</head>  
<body>  
  <div class="app">  
    <header class="header">  
      <div class="brand">  
        <div class="logo">D</div>  
        <div class="brand-text">  
          <h1>DIAZ</h1>  
          <span class="status"><span class="dot"></span> Online</span>  
        </div>  
      </div>  
      <button id="clearBtn" class="clear-btn" aria-label="Clear chat">Clear</button>  
    </header>  <main id="chat" class="chat" aria-live="polite">  
  <div class="message bot">  
    <div class="avatar">D</div>  
    <div class="bubble">  
      Hi, I'm <strong>DIAZ</strong> — your AI assistant. Ask me anything to get started.  
    </div>  
  </div>  
</main>  

<footer class="composer">  
  <div class="input-wrap">  
    <input  
      id="userInput"  
      type="text"  
      placeholder="Message DIAZ..."  
      autocomplete="off"  
      aria-label="Message input"  
    />  
    <button id="sendBtn" class="send-btn" aria-label="Send message">  
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">  
        <path d="M22 2 11 13"></path>  
        <path d="M22 2 15 22l-4-9-9-4 20-7z"></path>  
      </svg>  
    </button>  
  </div>  
  <p class="hint">DIAZ • Built for CodeAlpha Internship</p>  
</footer>

  </div>    <script src="script.js"></script>  </body>  
</html>
